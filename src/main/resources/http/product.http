@baseUrl = http://localhost:8080/api/v1
@artistId = f55eca4b-5793-4759-b857-be293f6630c3
@productId = 92a4272d-3309-4c21-89b0-2694365b3949
@track1Id = fe389960-62d6-4e6f-8341-d6e5695ad276
@track2Id = e9bf5bf7-8a0f-4a79-a810-8540ff211f10

### 1) Create artist (prerequisite)
POST {{baseUrl}}/artists
Content-Type: application/json

{
  "name": "Fleetwood Mac",
  "bio": "British-American rock band formed in London in 1967"
}

> {%
client.global.set("artistId", response.body.id);
%}

### 2) Create product as draft
POST {{baseUrl}}/products
Content-Type: application/json

{
  "title": "Rumours",
  "artistId": "{{artistId}}",
  "upc": "123456789012",
  "releaseDate": "1977-02-04",
  "genre": "ROCK",
  "price": {
    "amount": 9.99,
    "currency": "EUR"
  }
}

> {%
client.global.set("productId", response.body.id);
%}

### 3) Add first track
POST {{baseUrl}}/products/{{productId}}/tracks
Content-Type: application/json

{
  "title": "Second Hand News",
  "durationMs": 163000,
  "trackNumber": 1,
  "isrc": "USWB19900001"
}

> {%
client.global.set("track1Id", response.body.tracks[0].id);
%}

### 4) Add second track
POST {{baseUrl}}/products/{{productId}}/tracks
Content-Type: application/json

{
  "title": "Dreams",
  "durationMs": 254000,
  "trackNumber": 2,
  "isrc": "USWB19900002"
}

> {%
client.global.set("track1Id", response.body.tracks[0].id);
client.global.set("track2Id", response.body.tracks[1].id);
%}

### 5) Publish product
POST {{baseUrl}}/products/{{productId}}/publish

### 6) Update product metadata
PUT {{baseUrl}}/products/{{productId}}
Content-Type: application/json

{
  "title": "Rumours (Remastered)",
  "upc": "123456789012",
  "releaseDate": "1977-02-04",
  "genre": "ROCK",
  "price": {
    "amount": 12.99,
    "currency": "EUR"
  }
}

### 7) Reorder tracks
PUT {{baseUrl}}/products/{{productId}}/tracks/order
Content-Type: application/json

{
  "trackOrder": [
    "{{track2Id}}",
    "{{track1Id}}"
  ]
}

### 8) Get product
GET {{baseUrl}}/products/{{productId}}

### 9) List products
GET {{baseUrl}}/products?page=0&size=20&sort=title

### 10) Remove one track
DELETE {{baseUrl}}/products/{{productId}}/tracks/{{track2Id}}

### 11) Soft delete product (maps to takeDown)
DELETE {{baseUrl}}/products/{{productId}}

### Optional: direct takedown endpoint
POST {{baseUrl}}/products/{{productId}}/takedown
